# Copy this file to .env and adjust values for your local environment.
# Never commit the real .env file.

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- LLM Provider (see docs/AI_SYSTEM.md) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Embeddings (see docs/AI_SYSTEM.md) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Database ---
# Port 5433 is used (not 5432) to avoid colliding with a locally installed Postgres.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/resume_assistant
