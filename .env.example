# Copy this file to .env and adjust values for your local environment.
# Never commit the real .env file.

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- LLM Provider (see docs/AI_SYSTEM.md) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Embeddings (see docs/AI_SYSTEM.md) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Database (introduced starting Phase 1 / M4.1 pgvector setup) ---
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resume_assistant
